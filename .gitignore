# .gitignore (模板版)
# 复制到新项目后，将自动保护归档元数据不被误上传

# 1. 归档元数据
manifest.yaml
archive_gen.py
deploy.sh
Project_Summary.md
Archive_Log.md
nodejs-sshx_Project_Summary.md
nodejs-sshx_Archive_Log.md
nodejs-sshx_Project_Supplements.md

# 2. 知识库目录
_Archive/
_Notebook/

# 3. 子项目（单独部署，不入主仓库）
or/

# 4. 系统垃圾与临时文件
node_modules/
.env
*.log
*.tmp
__pycache__/
*:Zone.Identifier
.DS_Store
